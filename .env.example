# .env.example
# AutoCaption Environment Variables

# Django Security
# Generate a strong, random key for production. Do NOT share this key.
DJANGO_SECRET_KEY=generate-a-strong-key-here

# Set to True for development, False for production
DJANGO_DEBUG=True

# Set to True for permissive CORS, False for production
CORS_ALLOW_ALL_ORIGINS=True

# Database Configuration (PostgreSQL DSN)
DATABASE_URL=postgres://autocaption:autocaption@db:5432/autocaption

# Celery Broker Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
